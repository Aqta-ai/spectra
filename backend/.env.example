# Spectra Backend Configuration
#
# Option A — Vertex AI (recommended, required for gemini-2.5-flash-native-audio-latest)
# Run: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=europe-west1

# Option B — Google AI Studio (fallback, limited model availability)
# GOOGLE_API_KEY=your-gemini-api-key-here

# Optional: Spectra Overlay (Claude vision for page analysis)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000
