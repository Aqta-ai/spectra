# Spectra Backend Configuration
#
# Option A — Vertex AI (recommended, required for gemini-2.0-flash-exp)
# Run: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=europe-west1

# Option B — Google AI Studio (fallback, limited model availability)
# GOOGLE_API_KEY=your-gemini-api-key-here

# Optional: Spectra Overlay
# Uses the same Google Gemini credentials as the main app.

LOG_LEVEL=INFO
# Comma-separated; include your frontend origin(s) for CORS and WebSocket
ALLOWED_ORIGINS=http://localhost:3000,https://spectra.aqta.ai
# Optional: set to 1 or true to enable /vision-debug (leave unset in production)
# ENABLE_VISION_DEBUG=

# Optional: Spectra's voice (Gemini Live API). Default: Aoede (warm, breezy).
# Other options: Kore (cheerful), Puck (upbeat), Charon, Leda, Zephyr, etc.
# SPECTRA_VOICE=Aoede

# Optional: Offline mode via Ollama
# Set to "ollama" to use local Gemma 2 instead of Gemini Live API
# Requires: ollama serve running on localhost:11434, ollama pull gemma2
# SPECTRA_PROVIDER=gemini
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=gemma2
