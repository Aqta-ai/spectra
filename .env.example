# Spectra Backend Configuration

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# REQUIRED: API Keys
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Google Gemini API Key (required for Spectra to function)
GOOGLE_API_KEY=your_google_api_key_here

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPTIONAL: Spectra Orchestrator Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Interaction logging path (for ML training dataset)
# Default: logs/spectra_traces.jsonl
SPECTRA_INTERACTION_LOG_PATH=logs/spectra_traces.jsonl

# Screen context max age in seconds (when to refresh screen description)
# Default: 5
SPECTRA_SCREEN_CONTEXT_MAX_AGE=5

# Enable aggressive narration filtering (removes meta-commentary)
# Default: true
SPECTRA_AGGRESSIVE_NARRATION_FILTER=true

# Enable interaction logging (for fine-tuning dataset)
# Default: true
SPECTRA_LOG_INTERACTIONS=true

# Enable strict validation (fail on any system instruction violation)
# Default: false
SPECTRA_STRICT_VALIDATION=false

# Maximum log file size in MB (before rotation)
# Default: 100
SPECTRA_MAX_LOG_FILE_SIZE_MB=100

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPTIONAL: Logging Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: WARNING (minimal logging)
LOG_LEVEL=WARNING

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPTIONAL: Orchestrator Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# State management
# How long screen context is considered fresh (in seconds)
# Default: 5
SCREEN_CONTEXT_MAX_AGE=5

# Interaction logging
# Path to interaction log file for ML training
# Default: data/spectra_traces.jsonl
INTERACTION_LOG_PATH=data/spectra_traces.jsonl

# Enable/disable interaction logging
# Default: true
INTERACTION_LOG_ENABLED=true

# Response processing
# Minimum sentence length to keep (shorter sentences filtered as artifacts)
# Default: 10
MIN_SENTENCE_LENGTH=10

# Maximum response length (longer responses truncated)
# Default: 2000
MAX_RESPONSE_LENGTH=2000

# Regex compilation
# Enable regex pattern caching for performance
# Default: true
REGEX_CACHE_ENABLED=true

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPTIONAL: Performance Tuning
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Maximum number of frames to queue for processing
# Lower = faster processing, Higher = smoother under load
# Default: 3
MAX_FRAME_QUEUE=3

# Timeout for action execution (in seconds)
# Increase if actions are timing out prematurely
# Default: 12.0 (raised from 6s to accommodate page load wait after navigate)
ACTION_TIMEOUT=12.0

# Heartbeat interval (in seconds)
# How often to send keepalive messages to client
# Default: 3.0
HEARTBEAT_INTERVAL=3.0

# Frame processing cooldown (in seconds)
# Minimum time between processing frames
# Default: 0.01
FRAME_COOLDOWN=0.01

# Maximum concurrent actions
# How many actions can run in parallel
# Default: 2
MAX_CONCURRENT_ACTIONS=2

# Batch size for frame processing
# Default: 1 (process one frame at a time)
BATCH_SIZE=1

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPTIONAL: Vision System Caching
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Cache TTL for screen descriptions (in seconds)
# How long to cache vision analysis results
# Default: 3.0
DESCRIBE_CACHE_TTL=3.0

# Cooldown between screen descriptions (in seconds)
# Prevents excessive API calls
# Default: 0.3
DESCRIBE_COOLDOWN=0.3

# Maximum cache size (number of entries)
# Default: 20
CACHE_MAX_SIZE=20

# Minimum cache TTL (in seconds)
# Default: 2.0
CACHE_MIN_TTL=2.0

# Maximum cache TTL (in seconds)
# Default: 10.0
CACHE_MAX_TTL=10.0

# Target cache hit rate (0.0 to 1.0)
# System will adjust TTL to maintain this hit rate
# Default: 0.7 (70%)
CACHE_ADAPTIVE_THRESHOLD=0.7

# Frame similarity threshold (0.0 to 1.0)
# How similar frames must be to reuse cached description
# Default: 0.95 (95% similar)
FRAME_SIMILARITY_THRESHOLD=0.95

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPTIONAL: CORS Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Allowed origins for CORS (comma-separated)
# Default: http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
